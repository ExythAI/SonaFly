<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SonaFly.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="#0D0D1A">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <Label Text="⚙️ Settings" FontSize="24" FontAttributes="Bold" TextColor="#FFE66D" />

            <!-- Change Password -->
            <Border BackgroundColor="#1A1A2E" StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="CHANGE PASSWORD" FontSize="10" TextColor="#9AA0A6" CharacterSpacing="2" />

                    <Entry Placeholder="Current Password" IsPassword="True" Text="{Binding CurrentPassword}"
                           TextColor="#E8EAED" PlaceholderColor="#666" BackgroundColor="#252540" />

                    <Entry Placeholder="New Password" IsPassword="True" Text="{Binding NewPassword}"
                           TextColor="#E8EAED" PlaceholderColor="#666" BackgroundColor="#252540" />

                    <Entry Placeholder="Confirm New Password" IsPassword="True" Text="{Binding ConfirmPassword}"
                           TextColor="#E8EAED" PlaceholderColor="#666" BackgroundColor="#252540" />

                    <Button Text="Change Password" BackgroundColor="#4ECDC4" TextColor="#0D0D1A"
                            CornerRadius="12" FontSize="14" FontAttributes="Bold" Padding="16,10"
                            Command="{Binding ChangePasswordCommand}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#FFE66D" />

                    <Label Text="{Binding StatusMessage}" FontSize="12" TextColor="#4ECDC4" />
                </VerticalStackLayout>
            </Border>

            <!-- App Info -->
            <Border BackgroundColor="#1A1A2E" StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="ABOUT" FontSize="10" TextColor="#9AA0A6" CharacterSpacing="2" />
                    <Label Text="SonaFly" FontSize="16" FontAttributes="Bold" TextColor="#E8EAED" />
                    <Label Text="Personal Music Streaming Server" FontSize="12" TextColor="#9AA0A6" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
