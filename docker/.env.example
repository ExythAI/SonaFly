# SonaFly Environment Configuration
# Copy this file to .env and update the values before deploying.

# REQUIRED: JWT signing secret (minimum 32 characters)
# Generate one with: openssl rand -base64 48
JWT_SECRET=CHANGE-ME-generate-a-random-secret-at-least-32-characters

# Default admin password (only used on first startup when no admin exists)
ADMIN_DEFAULT_PASSWORD=Admin123!

# Database path (inside the container)
DB_CONNECTION=Data Source=/app/data/db/sonafly.db

# Artwork cache directory (inside the container)
ARTWORK_ROOT=/app/data/artwork
