{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=sonafly.db"
  },
  "Jwt": {
    "Secret": "SonaFly-Dev-Secret-Key-Must-Be-At-Least-32-Chars!",
    "Issuer": "SonaFly",
    "Audience": "SonaFlyClients",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "SonaFly": {
    "ArtworkRoot": "./data/artwork",
    "LibraryRoots": []
  }
}
